import http.client

conn = http.client.HTTPSConnection("api.leaseweb.com")

payload = "{\"resourceType\":\"string\",\"data\":[{\"key\":\"string\",\"value\":\"string\"}]}"

headers = {
    'X-LSW-Auth': "REPLACE_KEY_VALUE",
    'content-type': "application/json"
    }

conn.request("PUT", "/cdn/v2/originGroups/%7BoriginGroupId%7D/members/%7BoriginGroupMemberId%7D", payload, headers)

res = conn.getresponse()
data = res.read()

print(data.decode("utf-8"))